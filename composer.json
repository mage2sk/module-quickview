{
    "name": "mage2kishan/module-quickview",
    "description": "Smart Quick View & Compare module for Magento 2 with Hyva theme support. Features: Quick View Modal, Product Comparison, Recently Viewed Products",
    "type": "magento2-module",
    "version": "1.0.4",
    "license": [
        "proprietary"
    ],
    "authors": [
        {
            "name": "Kishan Savaliya",
            "email": "kishansavaliyakb@gmail.com",
            "homepage": "https://panthinfotech.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "magento/framework": "^103.0",
        "magento/module-catalog": "^104.0",
        "magento/module-customer": "^103.0",
        "magento/module-store": "^101.0",
        "magento/module-backend": "^102.0",
        "magento/module-config": "^101.0",
        "magento/module-catalog-inventory": "^100.0",
        "magento/module-review": "^100.0",
        "mage2kishan/module-core": "^1.0"
    },
    "suggest": {
        "hyva-themes/magento2-default-theme": "Optimized for Hyva theme with Alpine.js and Tailwind CSS"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Panth\\QuickView\\": ""
        }
    },
    "keywords": [
        "magento2",
        "quick-view",
        "product-comparison",
        "hyva-theme",
        "alpine-js",
        "tailwind-css"
    ]
}
