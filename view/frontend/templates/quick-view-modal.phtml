        </div>
    </div>
</div>

<script>
function quickViewModal() {
    return {
        show: false, loading: false, error: null, product: null,
        mainImage: '', qty: 1, addingToCart: false, cartSuccess: false,
        openModal(productId) {
            this.show = true; this.loading = true; this.error = null;
            this.product = null; this.qty = 1; this.cartSuccess = false;
            document.body.style.overflow = 'hidden';
            fetch('<?= $block->escapeJs($quickViewUrl) ?>?id=' + productId, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                .then(r => r.json())
                .then(data => {
                    if (data.success && data.product) { this.product = data.product; this.mainImage = data.product.images?.[0]?.url || ''; }
                    else { this.error = data.message || 'Product not found.'; }
                })
                .catch(() => this.error = 'Failed to load product.')
                .finally(() => this.loading = false);
        },
        closeModal() { this.show = false; document.body.style.overflow = ''; },
        async addToCart() {
            this.addingToCart = true;
            try {
                const fd = new FormData();
                fd.append('product', this.product.id);
                fd.append('qty', this.qty);
                fd.append('form_key', this.product.form_key);
                const r = await fetch('/checkout/cart/add/', { method: 'POST', body: fd, headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                if (r.ok || r.redirected) { this.cartSuccess = true; window.dispatchEvent(new CustomEvent('reload-customer-section-data')); setTimeout(() => this.closeModal(), 1200); }
            } catch(e) {}
            finally { this.addingToCart = false; }
        }
    };
}
</script>
