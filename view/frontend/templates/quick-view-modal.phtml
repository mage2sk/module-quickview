                                <div x-show="product?.images?.length > 1" class="qv-thumbs">
                                    <template x-for="(img, i) in (product?.images || [])" :key="i">
                                        <button class="qv-thumb" :class="mainImage === img.url && 'active'" @click="mainImage = img.url">
                                            <img :src="img.thumb_url || img.url" alt="Product thumbnail" :alt="img.alt || product?.name || 'Product image'" />
