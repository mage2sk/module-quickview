    .qv-wrapper { padding:8px !important; }
    .qv-modal { max-width:100% !important;max-height:85vh !important;border-radius:14px !important; }
    .qv-grid { grid-template-columns:1fr !important; }
    .qv-img-area { padding:12px !important;max-height:200px; }
    .qv-img-main { aspect-ratio:auto !important;height:170px; }
    .qv-thumbs { display:none !important; }
    .qv-info { padding:12px 16px 16px !important; }
    .qv-name { font-size:16px;padding-right:0; }
    .qv-close { top:8px;right:8px;width:50px !important;height:50px !important;min-width:50px !important;min-height:50px !important; }
    .qv-desc { max-height:60px;overflow:hidden;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical; }
}
</style>

<!-- Quick View Modal Container -->
<div class="qv-overlay" id="qv-overlay"></div>
<div class="qv-wrapper" id="qv-wrapper">
    <div class="qv-modal" id="qv-modal">
        <button class="qv-close" id="qv-close" type="button">
            <svg width="18" height="18" fill="none" stroke="#374151" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
        <div id="qv-content">
            <!-- Content injected by JS -->
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    'use strict';
    var overlay = document.getElementById('qv-overlay');
    var wrapper = document.getElementById('qv-wrapper');
    var content = document.getElementById('qv-content');
    var closeBtn = document.getElementById('qv-close');
    var currentProduct = null;
    var qty = 1;

    function openModal(productId) {
        currentProduct = null;
        qty = 1;
        content.innerHTML = '<div class="qv-loading"><p>Loading product...</p></div>';
        overlay.classList.add('active');
        wrapper.classList.add('active');
        document.body.style.overflow = 'hidden';

        fetch('<?= $block->escapeJs($quickViewUrl) ?>?id=' + productId, {
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success && data.product) {
                currentProduct = data.product;
                renderProduct(data.product);
            } else {
                content.innerHTML = '<div class="qv-error"><p>' + (data.message || 'Product not found.') + '</p></div>';
            }
        })
        .catch(function() {
            content.innerHTML = '<div class="qv-error"><p>Failed to load product.</p></div>';
        });
    }

    function closeModal() {
        overlay.classList.remove('active');
        wrapper.classList.remove('active');
        document.body.style.overflow = '';
    }

    function renderProduct(p) {
        var mainImg = (p.images && p.images[0]) ? p.images[0].url : '';
        var stockClass = p.in_stock ? 'in' : 'out';
        var stockText = p.in_stock ? '<svg width="12" height="12" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> In Stock' : 'Out of Stock';

        var thumbsHtml = '';
        if (p.images && p.images.length > 1) {
            thumbsHtml = '<div class="qv-thumbs">';
            p.images.forEach(function(img, i) {
                thumbsHtml += '<button class="qv-thumb' + (i === 0 ? ' active' : '') + '" data-img="' + escapeAttr(img.url) + '" type="button"><img src="' + escapeAttr(img.thumb_url || img.url) + '" alt="' + escapeAttr(img.alt || p.name || 'Product image') + '" /></button>';
            });
            thumbsHtml += '</div>';
        }

        var cartHtml = '';
        if (p.in_stock && (p.type_id === 'simple' || p.type_id === 'virtual')) {
            cartHtml = '<div class="qv-cart-row">' +
                '<div class="qv-qty-wrap">' +
                '<button class="qv-qty-btn" type="button" id="qv-qty-minus">\u2212</button>' +
                '<input class="qv-qty-input" type="number" id="qv-qty" value="1" min="1" max="99" />' +
                '<button class="qv-qty-btn" type="button" id="qv-qty-plus">+</button>' +
                '</div>' +
                '<button class="qv-btn-cart" type="button" id="qv-add-cart">' +
                '<svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/></svg>' +
                '<span>Add to Cart</span></button></div>';
        } else if (p.in_stock) {
            cartHtml = '<p class="qv-note">This product has options. Please visit the product page to select.</p>' +
                '<a href="' + escapeAttr(p.url) + '" class="qv-btn-options">' +
                '<svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/></svg>' +
                'Select Options</a>';
        }

        var descHtml = (p.short_description && p.short_description.length > 0) ?
            '<p class="qv-desc">' + p.short_description + '</p>' : '';

        content.innerHTML =
            '<div style="overflow-y:auto;flex:1;"><div class="qv-grid">' +
            '<div class="qv-img-area">' +
            '<div class="qv-img-main"><img id="qv-main-img" src="' + escapeAttr(mainImg) + '" alt="' + escapeAttr(p.name) + '" /></div>' +
            thumbsHtml +
            '</div>' +
            '<div class="qv-info">' +
            '<p class="qv-name">' + escapeHtml(p.name) + '</p>' +
            '<p class="qv-sku">SKU: ' + escapeHtml(p.sku) + '</p>' +
            '<div class="qv-price">' + p.price_html + '</div>' +
            '<span class="qv-stock ' + stockClass + '">' + stockText + '</span>' +
            descHtml +
            '<div style="flex:1;min-height:8px;"></div>' +
            cartHtml +
            '<a href="' + escapeAttr(p.url) + '" class="qv-link">View Full Details \u2192</a>' +
            '</div></div></div>';

        // Bind thumbnail clicks
        content.querySelectorAll('.qv-thumb').forEach(function(thumb) {
            thumb.addEventListener('click', function() {
                var img = this.getAttribute('data-img');
                document.getElementById('qv-main-img').src = img;
                content.querySelectorAll('.qv-thumb').forEach(function(t) { t.classList.remove('active'); });
                this.classList.add('active');
            });
        });

        // Bind qty buttons
        var qtyInput = document.getElementById('qv-qty');
        var minusBtn = document.getElementById('qv-qty-minus');
        var plusBtn = document.getElementById('qv-qty-plus');
        if (minusBtn) minusBtn.addEventListener('click', function() { if (parseInt(qtyInput.value) > 1) qtyInput.value = parseInt(qtyInput.value) - 1; });
        if (plusBtn) plusBtn.addEventListener('click', function() { qtyInput.value = parseInt(qtyInput.value) + 1; });

        // Bind add to cart
        var cartBtn = document.getElementById('qv-add-cart');
        if (cartBtn) {
            cartBtn.addEventListener('click', function() {
                cartBtn.disabled = true;
                cartBtn.innerHTML = '<svg style="width:16px;height:16px;" class="animate-spin" fill="none" viewBox="0 0 24 24"><circle style="opacity:0.25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path style="opacity:0.75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/></svg>';

                var fd = new FormData();
                fd.append('product', currentProduct.id);
                fd.append('qty', qtyInput ? qtyInput.value : 1);
                fd.append('form_key', currentProduct.form_key);

                fetch('/checkout/cart/add/', {
                    method: 'POST',
                    body: fd,
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                }).then(function(r) {
                    cartBtn.classList.add('success');
                    cartBtn.innerHTML = '<svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span>Added!</span>';
                    // Reload minicart
                    if (window.jQuery) {
                        window.jQuery('[data-block="minicart"]').trigger('contentLoading');
                        window.jQuery.ajax({ url: '/customer/section/load/?sections=cart', type: 'GET' });
                    }
                    setTimeout(closeModal, 1200);
                }).catch(function() {
                    cartBtn.disabled = false;
                    cartBtn.innerHTML = '<span>Error - Try Again</span>';
                });
            });
        }
    }

    function escapeHtml(str) {
        if (!str) return '';
        var d = document.createElement('div');
        d.appendChild(document.createTextNode(str));
        return d.innerHTML;
    }

    function escapeAttr(str) {
        return (str || '').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/'/g,'&#39;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    // Close handlers
    closeBtn.addEventListener('click', closeModal);
    overlay.addEventListener('click', closeModal);
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeModal(); });
    document.getElementById('qv-modal').addEventListener('click', function(e) { e.stopPropagation(); });

    // Listen for quickview trigger
    window.addEventListener('open-quick-view', function(e) {
        if (e.detail && e.detail.productId) openModal(e.detail.productId);
    });

    // Also listen for click on quickview buttons (Luma product listing)
    document.body.addEventListener('click', function(e) {
        var btn = e.target.closest('[data-quickview-id]');
        if (btn) {
            e.preventDefault();
            openModal(btn.getAttribute('data-quickview-id'));
        }
    });
});

// Spinner animation
var qvSpinStyle = document.createElement('style');
qvSpinStyle.textContent = '@keyframes animate-spin { to { transform: rotate(360deg); } } .animate-spin { animation: animate-spin 1s linear infinite; }' +
    '.qv-action-btn { display:inline-flex;align-items:center;justify-content:center;width:32px;height:32px;border:1px solid #e5e5e5;border-radius:50%;background:#fff;color:#525252;cursor:pointer;transition:all 0.2s;padding:0;flex-shrink:0; }' +
    '.qv-action-btn:hover { border-color:var(--color-primary, #0D9488);color:var(--color-primary, #0D9488);background:#f0fdfa; }' +
    '.qv-action-btn svg { width:16px;height:16px; }';
document.head.appendChild(qvSpinStyle);

// Inject QuickView eye icon buttons in product actions area (beside wishlist/compare)
function injectQuickViewButtons() {
    document.querySelectorAll('li.product-item, .product-item').forEach(function(item) {
        if (item.querySelector('.qv-action-btn')) return;

        // Find product ID
        var productId = null;
        var form = item.querySelector('form[data-product-sku]');
        var idInput = form ? form.querySelector('input[name="product"]') : null;
        if (idInput) productId = idInput.value;
        if (!productId) {
            var wishBtn = item.querySelector('[data-post]');
            if (wishBtn) {
                try { var d = JSON.parse(wishBtn.getAttribute('data-post')); productId = d.data && d.data.product; } catch(e) {}
            }
        }
        if (!productId) return;

        // Find actions area (where wishlist/compare icons are)
        var actionsArea = item.querySelector('.product-item-actions .actions-secondary') ||
                          item.querySelector('.actions-secondary') ||
                          item.querySelector('.product-item-inner .actions-secondary');
        if (!actionsArea) return;

        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'qv-action-btn action';
        btn.setAttribute('data-quickview-id', productId);
        btn.setAttribute('title', 'Quick View');
        btn.innerHTML = '<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>';
        actionsArea.appendChild(btn);
    });
}
setTimeout(injectQuickViewButtons, 500);
setTimeout(injectQuickViewButtons, 2000);
</script>
