.qv-qty-input { width:32px;height:42px;border:none !important;text-align:center;font-size:14px;font-weight:600;outline:none;background:transparent;-moz-appearance:textfield;padding:0 !important;min-height:auto !important;border-radius:0 !important;box-shadow:none !important; }
.qv-qty-input::-webkit-outer-spin-button,.qv-qty-input::-webkit-inner-spin-button { -webkit-appearance:none;margin:0; }
.qv-btn-cart { flex:1;padding:12px 16px;border:none;font-size:15px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;color:#fff !important;background:var(--color-primary, #0D9488) !important;transition:all 0.2s; }
.qv-btn-cart:hover { filter:brightness(0.9); }
.qv-btn-cart.success { background:#16a34a; }
